   "source": [
    "import numpy as np\n",
    "\n",
    "# Fast number crunching with NumPy\n",
    "a = np.arange(1, 11)\n",
    "b = np.linspace(10, 100, 10)\n",
    "\n",
    "# vectorized operations\n",
    "sum_ab = a + b\n",
    "prod_ab = a * b\n",
    "mean_ab = np.mean(sum_ab)\n",
    "std_ab = np.std(prod_ab)\n",
    "\n",
    "a, b, sum_ab, prod_ab, mean_ab, std_ab"
   ]
  },
